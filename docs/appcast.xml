      <enclosure
        url="https://github.com/beerbeatbox/claudebar/releases/download/v1.5.2/ClaudeBar-1.5.2.zip"
        sparkle:os="macos"
        sparkle:edSignature="lJ3Uc8F6OJoUpQxRQJTCBxGGNVffMHhXHgXEWH74XSZGNpbZzBBA9hPVceuq2QGzDEecVYDWlK655YqH7QjaCA=="
