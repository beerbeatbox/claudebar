<?xml version="1.0" encoding="utf-8"?>
<!--
  ClaudeBar Sparkle appcast.

  Served via GitHub Pages at:
    https://beerbeatbox.github.io/claudebar/appcast.xml
  One-time setup: GitHub repo Settings > Pages > Build and deployment >
  Source "Deploy from a branch" > Branch "main" / folder "/docs".

  PER RELEASE: prepend a fresh <item> inside <channel> (newest first). Get the
  edSignature + length from `rps ship` output (it runs sign_update on the zip),
  or run: dart run auto_updater:sign_update build/dist/ClaudeBar-X.Y.Z.zip

  Item template (copy, fill in, place directly below <language>):

    <item>
      <title>Version X.Y.Z</title>
      <sparkle:version>N</sparkle:version>
      <sparkle:shortVersionString>X.Y.Z</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>10.15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[ <ul><li>What changed.</li></ul> ]]></description>
      <pubDate>Day, DD Mon YYYY HH:MM:SS +0000</pubDate>
      <enclosure
        url="https://github.com/beerbeatbox/claudebar/releases/download/vX.Y.Z/ClaudeBar-X.Y.Z.zip"
        sparkle:os="macos"
        sparkle:edSignature="PASTE_FROM_sign_update"
        length="PASTE_FROM_sign_update"
        type="application/octet-stream" />
    </item>

  Notes:
    * sparkle:version is CFBundleVersion = the pubspec build number (the +N).
      It is what Sparkle compares to decide "is there a newer build"; it MUST
      strictly increase every release. shortVersionString is display-only.
    * sparkle:minimumSystemVersion must be three-part (10.15.0, not 10.15).
    * length is bytes; sign_update computes it, do not hand-edit.
    * The enclosure points at the .zip release asset, not the .dmg.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
  <channel>
    <title>ClaudeBar Changelog</title>
    <link>https://beerbeatbox.github.io/claudebar/appcast.xml</link>
    <description>Most recent ClaudeBar updates.</description>
    <language>en</language>
    <item>
      <title>Version 1.5.7</title>
      <sparkle:version>20</sparkle:version>
      <sparkle:shortVersionString>1.5.7</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>10.15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[ <ul><li>**Fixes ClaudeBar hanging at launch with no menu-bar icon** — a Flutter engine change had merged the platform and UI threads, which could deadlock the menu-bar setup on startup so the app never appeared (and couldn&#x27;t be reopened). ClaudeBar now opts out of that mode and launches reliably.</li><li>Lost the menu-bar icon after sleep/wake? Just open ClaudeBar again from Applications or Spotlight and the icon comes right back — no force-quit needed.</li><li>Clearer guidance when the Claude Code CLI is missing or broken: ClaudeBar now says &quot;Claude Code not found&quot; and tells you to install it, instead of a misleading &quot;update the app&quot; message.</li></ul> ]]></description>
      <pubDate>Mon, 22 Jun 2026 07:56:30 +0000</pubDate>
      <enclosure
        url="https://github.com/beerbeatbox/claudebar/releases/download/v1.5.7/ClaudeBar-1.5.7.zip"
        sparkle:os="macos"
        sparkle:edSignature="5sQ85EH+BmZf8IxbXRoiFZjOnGP+g5eriKrs240Oi1PPh+NfEW6qXTxrh5T+jSDhYJ8Bpkc1rUO1ylnpxEbxBQ=="
        length="17490874"
        type="application/octet-stream" />
    </item>
