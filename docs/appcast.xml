        url="https://github.com/beerbeatbox/claudebar/releases/download/v1.5.3/ClaudeBar-1.5.3.zip"
        sparkle:os="macos"
        sparkle:edSignature="bAJZxvtjKgdlMKp1/cEJPzbe33pZpnpSK/XAR14exmfTWa/amPXZjnA6bcA57ERTikORkgD50Ijy/S2bY9JnAg=="
